parameters:
    level: 6
    paths:
        - includes
    scanFiles:
        - resa.php
        - uninstall.php
    bootstrapFiles:
        - tests/php/bootstrap.php
    ignoreErrors:
        # WordPress functions are defined at runtime.
        - '#Function [a-z_]+ not found\.#'
    treatPhpDocTypesAsCertain: false
