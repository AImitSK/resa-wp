{
	"name": "resa",
	"private": true,
	"version": "0.4.1",
	"type": "module",
	"scripts": {
		"dev": "vite",
		"build": "tsc --noEmit && vite build",
		"preview": "vite preview",
		"lint": "eslint src/ tests/js/",
		"lint:fix": "eslint src/ tests/js/ --fix",
		"format": "prettier --write \"src/**/*.{ts,tsx}\" \"tests/js/**/*.{ts,tsx}\"",
		"format:check": "prettier --check \"src/**/*.{ts,tsx}\" \"tests/js/**/*.{ts,tsx}\"",
		"test": "vitest",
		"test:coverage": "vitest --coverage",
		"i18n:pot": "wp i18n make-pot . languages/resa.pot --domain=resa --exclude=node_modules,vendor,dist,tests",
		"i18n:update": "wp i18n update-po languages/resa.pot languages/",
		"i18n:mo": "wp i18n make-mo languages/",
		"i18n:json": "wp i18n make-json languages/ --no-purge",
		"i18n:build": "npm run i18n:pot && npm run i18n:update && npm run i18n:mo && npm run i18n:json",
		"plugin:build": "npm run build && npm run i18n:build && composer install --no-dev --optimize-autoloader",
		"plugin:zip": "npm run plugin:build && node scripts/create-zip.js",
		"version:bump": "node scripts/bump-version.js",
		"prepare": "husky"
	},
	"dependencies": {
		"@hookform/resolvers": "^5.2.2",
		"@nivo/bar": "^0.99.0",
		"@nivo/core": "^0.99.0",
		"@nivo/line": "^0.99.0",
		"@radix-ui/react-checkbox": "^1.3.3",
		"@radix-ui/react-dialog": "^1.1.15",
		"@radix-ui/react-dropdown-menu": "^2.1.16",
		"@radix-ui/react-label": "^2.1.8",
		"@radix-ui/react-popover": "^1.1.15",
		"@radix-ui/react-radio-group": "^1.3.8",
		"@radix-ui/react-scroll-area": "^1.2.10",
		"@radix-ui/react-select": "^2.2.6",
		"@radix-ui/react-separator": "^1.1.8",
		"@radix-ui/react-slider": "^1.3.6",
		"@radix-ui/react-slot": "^1.2.4",
		"@radix-ui/react-switch": "^1.2.6",
		"@radix-ui/react-tabs": "^1.1.13",
		"@tanstack/react-query": "^5.90.21",
		"@tanstack/react-table": "^8.21.3",
		"@tiptap/extension-link": "^3.20.0",
		"@tiptap/extension-placeholder": "^3.20.0",
		"@tiptap/pm": "^3.20.0",
		"@tiptap/react": "^3.20.0",
		"@tiptap/starter-kit": "^3.20.0",
		"@types/leaflet": "^1.9.21",
		"@vis.gl/react-google-maps": "^1.7.1",
		"@wordpress/i18n": "^6.13.0",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"date-fns": "^4.1.0",
		"framer-motion": "^12.34.3",
		"leaflet": "^1.9.4",
		"lucide-react": "^0.575.0",
		"react": "^18.3.1",
		"react-day-picker": "^9.14.0",
		"react-dom": "^18.3.1",
		"react-hook-form": "^7.71.2",
		"react-leaflet": "^4.2.1",
		"react-resizable-panels": "^4.7.0",
		"react-router-dom": "^7.13.1",
		"tailwind-merge": "^2.6.1",
		"zod": "^4.3.6"
	},
	"devDependencies": {
		"@eslint/js": "^9.39.3",
		"@testing-library/jest-dom": "^6.9.1",
		"@testing-library/react": "^16.3.2",
		"@testing-library/user-event": "^14.6.1",
		"@types/react": "^18.3.18",
		"@types/react-dom": "^18.3.5",
		"@types/wordpress__i18n": "^3.4.0",
		"@vitejs/plugin-react": "^4.3.4",
		"archiver": "^7.0.1",
		"autoprefixer": "^10.4.24",
		"eslint": "^9.39.3",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-react": "^7.37.5",
		"eslint-plugin-react-hooks": "^7.0.1",
		"husky": "^9.1.7",
		"jsdom": "^25.0.1",
		"lint-staged": "^16.2.7",
		"postcss": "^8.5.6",
		"prettier": "^3.8.1",
		"shadcn": "^3.8.5",
		"tailwindcss": "^3.4.19",
		"tailwindcss-animate": "^1.0.7",
		"typescript": "~5.7.0",
		"typescript-eslint": "^8.56.1",
		"vite": "^6.0.0",
		"vitest": "^4.0.18"
	},
	"lint-staged": {
		"*.{ts,tsx}": [
			"eslint --fix",
			"prettier --write"
		],
		"*.{json,css,md}": [
			"prettier --write"
		]
	}
}
