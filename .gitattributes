# Auto detect text files and normalize to LF
* text=auto

# Shell scripts must always use LF (for Docker/Linux)
*.sh text eol=lf

# Batch files use CRLF (Windows)
*.bat text eol=crlf
*.cmd text eol=crlf

# PHP, JS, CSS - normalize
*.php text eol=lf
*.js text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.jsx text eol=lf
*.css text eol=lf
*.json text eol=lf
*.md text eol=lf
*.yml text eol=lf
*.yaml text eol=lf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
*.pdf binary
*.zip binary
